datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id                String    @id @default(uuid())
  fullname          String
  email             String    @unique
  supabaseId        String    @unique
  refreshToken      String?
  refreshTokenExpiry DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  updatedAt DateTime @updatedAt

  @@map("users")
  @@index([email])
}

